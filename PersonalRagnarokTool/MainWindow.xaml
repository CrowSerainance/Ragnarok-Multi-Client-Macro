                                                        <Grid Margin="0,2">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="120" />
                                                                <ColumnDefinition Width="80" />
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBox Text="{Binding Key}" infra:HotkeyCapture.IsEnabled="True" Style="{StaticResource EditorTextBox}" Margin="0,0,4,0" />
                                                            <TextBox Grid.Column="1" Text="{Binding DelayMs}" Style="{StaticResource EditorTextBox}" Margin="4,0" />
                                                            <CheckBox Grid.Column="2" Content="Click" IsChecked="{Binding HasClick}" VerticalAlignment="Center" Margin="8,0" />
                                                            <Button Grid.Column="3" Content="x" Command="{Binding DataContext.RemoveSongEntryCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Style="{StaticResource SecondaryBtn}" Padding="8,2" Margin="0" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                            <Button Content="+ Add Entry" Command="{Binding DataContext.AddSongEntryCommand, RelativeSource={RelativeSource AncestorType=Window}}" Style="{StaticResource SecondaryBtn}" HorizontalAlignment="Left" Margin="0,8,0,0" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ═══════════ TAB: SERVERS ═══════════ -->
                <TabItem Header="Servers">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="0,16,0,0">
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Server Management" FontSize="18" FontWeight="Bold" />
                                    <Separator Margin="0,12" />
                                    <ListBox ItemsSource="{Binding Servers}" BorderThickness="0" Background="Transparent">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="160" />
                                                        <ColumnDefinition Width="120" />
                                                        <ColumnDefinition Width="140" />
                                                        <ColumnDefinition Width="140" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox Text="{Binding Name}" Style="{StaticResource EditorTextBox}" Margin="0,0,4,0" />
                                                    <TextBox Grid.Column="1" Text="{Binding ProcessName}" Style="{StaticResource EditorTextBox}" Margin="4,0" />
                                                    <TextBox Grid.Column="2" Text="{Binding HpAddress}" Style="{StaticResource EditorTextBox}" Margin="4,0" />
                                                    <TextBox Grid.Column="3" Text="{Binding NameAddress}" Style="{StaticResource EditorTextBox}" Margin="4,0" />
                                                    <Button Grid.Column="4" Content="x" Command="{Binding DataContext.RemoveServerCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Style="{StaticResource SecondaryBtn}" Padding="8,2" Margin="4,0,0,0" />
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                    <Grid Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="160" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="140" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Name" FontWeight="SemiBold" FontSize="11" Foreground="{StaticResource MutedInk}" />
                                        <TextBlock Grid.Column="1" Text="Process" FontWeight="SemiBold" FontSize="11" Foreground="{StaticResource MutedInk}" Margin="4,0" />
                                        <TextBlock Grid.Column="2" Text="HP Address" FontWeight="SemiBold" FontSize="11" Foreground="{StaticResource MutedInk}" Margin="4,0" />
                                        <TextBlock Grid.Column="3" Text="Name Address" FontWeight="SemiBold" FontSize="11" Foreground="{StaticResource MutedInk}" Margin="4,0" />
                                    </Grid>
                                    <Button Content="+ Add Server" Command="{Binding AddServerCommand}" Style="{StaticResource SecondaryBtn}" Margin="0,12,0,0" HorizontalAlignment="Left" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

            </TabControl>

            <!-- STATUS BAR -->
            <Border Grid.Row="2" Margin="16,0,16,16" Padding="14,10" Background="{StaticResource CardBg}" BorderBrush="{StaticResource CardBorder}" BorderThickness="1" CornerRadius="8">
                <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource InkBrush}" TextWrapping="Wrap" />
            </Border>
        </Grid>
    </Grid>
</Window>
