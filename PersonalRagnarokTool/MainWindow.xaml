<Window x:Class="PersonalRagnarokTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:infra="clr-namespace:PersonalRagnarokTool.Infrastructure"
        xmlns:models="clr-namespace:PersonalRagnarokTool.Core.Models;assembly=PersonalRagnarokTool.Core"
        mc:Ignorable="d"
        Title="Ragnarok Control Deck"
        Width="1280"
        Height="780"
        MinWidth="1080"
        MinHeight="680"
        Background="#F3EEE2"
        FontFamily="Bahnschrift">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <infra:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVisibility" />
        <infra:NullToBooleanConverter x:Key="NullToBoolean" />

        <SolidColorBrush x:Key="SidebarBrush" Color="#E6D8BC" />
        <SolidColorBrush x:Key="CardBrush" Color="#FFFDF8" />
        <SolidColorBrush x:Key="CardAltBrush" Color="#F7EEDA" />
        <SolidColorBrush x:Key="InkBrush" Color="#111111" />
        <SolidColorBrush x:Key="MutedInkBrush" Color="#4F4A40" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#D3C3A5" />
        <SolidColorBrush x:Key="AccentDeepBrush" Color="#C68400" />
        <SolidColorBrush x:Key="AlertBrush" Color="#B42318" />
        <LinearGradientBrush x:Key="WindowBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F6F1E7" Offset="0" />
            <GradientStop Color="#EFE4CC" Offset="0.55" />
            <GradientStop Color="#F9F4EA" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="HeaderBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#FFF7E0" Offset="0" />
            <GradientStop Color="#F3D48A" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="PrimaryButtonBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFD45B" Offset="0" />
            <GradientStop Color="#F4B400" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="SidebarHeaderBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#1A1A1A" Offset="0" />
            <GradientStop Color="#39342A" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="18"
                                      ShadowDepth="0"
                                      Opacity="0.12"
                                      Color="#7A6645" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SmallButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource CardAltBrush}" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#FDE8B5" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource AccentDeepBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#F7D16D" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource SmallButtonStyle}">
            <Setter Property="Background" Value="{StaticResource PrimaryButtonBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentDeepBrush}" />
        </Style>

        <Style x:Key="EditorTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#FFFDF9" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="7,5" />
            <Setter Property="Margin" Value="0,6,0,0" />
            <Setter Property="CaretBrush" Value="{StaticResource InkBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="TextBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="TextBorder" Property="BorderBrush" Value="{StaticResource AccentDeepBrush}" />
                                <Setter TargetName="TextBorder" Property="Background" Value="#FFF8E8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EditorComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#FFFDF9" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="5,3" />
            <Setter Property="Margin" Value="0,6,0,0" />
        </Style>

        <Style x:Key="SidebarListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
        </Style>

        <Style x:Key="PanelListBoxStyle" TargetType="ListBox" BasedOn="{StaticResource SidebarListBoxStyle}">
            <Setter Property="Background" Value="#FFF9EC" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6" />
        </Style>

        <Style x:Key="ListBoxItemChromeStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="Transparent"
                                CornerRadius="16"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#FFF1C9" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#FFF7E1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource WindowBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Width="{Binding SidebarWidth}"
                Background="{StaticResource SidebarBrush}"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="10,10,10,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Background="{StaticResource SidebarHeaderBrush}"
                            CornerRadius="16"
                            Padding="16,12"
                            Margin="0,0,8,0"
                            Visibility="{Binding IsSidebarCollapsed, Converter={StaticResource InverseBoolToVisibility}}">
                        <StackPanel>
                            <TextBlock Text="control deck"
                                       Foreground="#FFF7E0"
                                       FontSize="20"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="Profiles, live status, and quick controls"
                                       Foreground="#F5DFC0"
                                       FontSize="12"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                    </Border>
                    <Button Grid.Column="1"
                            Content="{Binding SidebarToggleLabel}"
                            Command="{Binding ToggleSidebarCommand}"
                            Style="{StaticResource SmallButtonStyle}"
                            Width="34"
                            Height="34"
                            Margin="0" />
                </Grid>

                <StackPanel Grid.Row="1"
                            Margin="10,14,10,0"
                            Visibility="{Binding IsSidebarCollapsed, Converter={StaticResource InverseBoolToVisibility}}">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="remove client -"
                                Command="{Binding RemoveSelectedClientCommand}"
                                Style="{StaticResource SmallButtonStyle}" />
                        <Button Content="add client +"
                                Command="{Binding AddClientCommand}"
                                Style="{StaticResource PrimaryButtonStyle}" />
                    </StackPanel>
                    <TextBlock Text="{Binding HotkeyStatus}"
                               Foreground="{StaticResource MutedInkBrush}"
                               FontSize="12"
                               TextWrapping="Wrap" />
                </StackPanel>

                <ListBox Grid.Row="2"
                         Margin="10,14,10,10"
                         ItemsSource="{Binding ClientProfiles}"
                         SelectedItem="{Binding SelectedClient}"
                         Style="{StaticResource SidebarListBoxStyle}"
                         ItemContainerStyle="{StaticResource ListBoxItemChromeStyle}"
                         Visibility="{Binding IsSidebarCollapsed, Converter={StaticResource InverseBoolToVisibility}}">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:ClientProfile}">
                            <Border Margin="0,0,0,10"
                                    Padding="14"
                                    Background="{StaticResource CardBrush}"
                                    BorderBrush="{StaticResource BorderBrushSoft}"
                                    BorderThickness="1"
                                    CornerRadius="16">
                                <StackPanel>
                                    <TextBlock Text="{Binding DisplayName}"
                                               Foreground="{StaticResource InkBrush}"
                                               FontWeight="SemiBold"
                                               FontSize="16" />
                                    <TextBlock Text="{Binding BoundWindowDisplayText}"
                                               Foreground="{StaticResource MutedInkBrush}"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               Margin="0,4,0,0" />
                                    <TextBlock Text="{Binding RuntimeStatusLabel}"
                                               Foreground="{StaticResource AccentDeepBrush}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Margin="0,6,0,0" />
                                    <TextBlock Text="{Binding RuntimeStatusDetail}"
                                               Foreground="{StaticResource MutedInkBrush}"
                                               FontSize="11"
                                               TextWrapping="Wrap"
                                               Margin="0,2,0,0" />
                                    <TextBlock Text="{Binding Bindings.Count, StringFormat='Bindings: {0}'}"
                                               Foreground="{StaticResource InkBrush}"
                                               FontSize="12"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Margin="16,16,16,12"
                    Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Background="{StaticResource HeaderBrush}"
                            CornerRadius="16"
                            Padding="16,14">
                        <StackPanel>
                        <TextBlock Text="Ragnarok Control Deck"
                                       Foreground="{StaticResource InkBrush}"
                                       FontSize="26"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="Multi-client macro dispatch with precise activity zones, trace capture, and background hotkeys."
                                       Foreground="{StaticResource MutedInkBrush}"
                                       FontSize="13"
                                       Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="refresh windows"
                                Command="{Binding RefreshWindowsCommand}"
                                Style="{StaticResource SmallButtonStyle}" />
                        <Button Content="save"
                                Command="{Binding SaveCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Margin="0" />
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto">
                <Grid Margin="16,0,16,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Style="{StaticResource CardBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="280" />
                                <ColumnDefinition Width="320" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Margin="0,0,12,0">
                                <TextBlock Text="Selected client"
                                           Foreground="{StaticResource InkBrush}"
                                           FontSize="16"
                                           FontWeight="SemiBold" />
                                <TextBox Style="{StaticResource EditorTextBoxStyle}"
                                         Text="{Binding SelectedClient.DisplayName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         IsEnabled="{Binding SelectedClient, Converter={StaticResource NullToBoolean}}" />
                                <CheckBox Content="client enabled"
                                          IsChecked="{Binding SelectedClient.IsEnabled, Mode=TwoWay}"
                                          Foreground="{StaticResource InkBrush}"
                                          Margin="0,10,0,0" />
                                <TextBlock Text="{Binding SelectedClient.BoundWindowDisplayText}"
                                           Foreground="{StaticResource MutedInkBrush}"
                                           Margin="0,10,0,0"
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                <TextBlock Text="Window binding"
                                           Foreground="{StaticResource InkBrush}"
                                           FontSize="16"
                                           FontWeight="SemiBold" />
                                <ComboBox ItemsSource="{Binding AvailableWindows}"
                                          SelectedItem="{Binding SelectedAvailableWindow}"
                                          DisplayMemberPath="DisplayText"
                                          Style="{StaticResource EditorComboBoxStyle}" />
                                <WrapPanel Margin="0,10,0,0">
                                    <Button Content="bind selected window"
                                            Command="{Binding BindSelectedClientCommand}"
                                            Style="{StaticResource PrimaryButtonStyle}" />
                                    <Button Content="resolve live window"
                                            Command="{Binding ResolveSelectedClientCommand}"
                                            Style="{StaticResource SmallButtonStyle}" />
                                    <Button Content="unbind"
                                            Command="{Binding UnbindSelectedClientCommand}"
                                            Style="{StaticResource SmallButtonStyle}"
                                            Margin="0" />
                                </WrapPanel>
                                <Button Content="refresh preview"
                                        Command="{Binding RefreshPreviewCommand}"
                                        Style="{StaticResource SmallButtonStyle}"
                                        Margin="0,10,0,0" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Runtime status"
                                           Foreground="{StaticResource InkBrush}"
                                           FontSize="16"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="{Binding SelectedClientBindingStatus}"
                                           Foreground="{StaticResource AccentDeepBrush}"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Margin="0,8,0,0"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding SelectedClientBindingDetail}"
                                           Foreground="{StaticResource InkBrush}"
                                           Margin="0,6,0,0"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding PreviewStatus}"
                                           Foreground="{StaticResource MutedInkBrush}"
                                           Margin="0,10,0,0"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding HotkeyStatus}"
                                           Foreground="{StaticResource MutedInkBrush}"
                                           Margin="0,10,0,0"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1"
                            Margin="0,16,0,0"
                            Style="{StaticResource CardBorderStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <WrapPanel Grid.Row="0" Margin="0,0,0,10">
                                <Button Content="new polygon"
                                        Command="{Binding NewPolygonCommand}"
                                        Style="{StaticResource SmallButtonStyle}" />
                                <Button Content="close polygon"
                                        Command="{Binding ClosePolygonCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}" />
                                <Button Content="delete vertex"
                                        Command="{Binding DeleteSelectedVertexCommand}"
                                        Style="{StaticResource SmallButtonStyle}" />
                                <Button Content="clear polygon"
                                        Command="{Binding ClearPolygonCommand}"
                                        Style="{StaticResource SmallButtonStyle}" />
                                <TextBlock Text="Left-click empty space to add vertices. Left-click a vertex to drag it."
                                           Foreground="{StaticResource MutedInkBrush}"
                                           VerticalAlignment="Center"
                                           Margin="8,4,0,0" />
                            </WrapPanel>

                            <ScrollViewer Grid.Row="1"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Auto">
                                <Border BorderBrush="{StaticResource BorderBrushSoft}"
                                        BorderThickness="1"
                                        CornerRadius="16"
                                        Background="#FFF8E6"
                                        Padding="8">
                                    <Grid Width="{Binding PreviewWidth}" Height="{Binding PreviewHeight}">
                                        <Image Source="{Binding PreviewImage}"
                                               Stretch="Fill" />
                                        <Canvas x:Name="PreviewCanvas"
                                                Width="{Binding PreviewWidth}"
                                                Height="{Binding PreviewHeight}"
                                                Background="Transparent"
                                                MouseLeftButtonDown="PreviewCanvas_OnMouseLeftButtonDown"
                                                MouseLeftButtonUp="PreviewCanvas_OnMouseLeftButtonUp"
                                                MouseMove="PreviewCanvas_OnMouseMove"
                                                SizeChanged="PreviewCanvas_OnSizeChanged" />
                                    </Grid>
                                </Border>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="2" Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="340" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Style="{StaticResource CardBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="Traces"
                                           Foreground="{StaticResource InkBrush}"
                                           FontSize="16"
                                           FontWeight="SemiBold" />
                                <TextBox Style="{StaticResource EditorTextBoxStyle}"
                                         Text="{Binding NewTraceName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <WrapPanel Margin="0,10,0,10">
                                    <Button Content="add trace"
                                            Command="{Binding AddTraceCommand}"
                                            Style="{StaticResource PrimaryButtonStyle}" />
                                    <Button Content="remove trace"
                                            Command="{Binding RemoveTraceCommand}"
                                            Style="{StaticResource SmallButtonStyle}" />
                                    <Button Content="start record"
                                            Command="{Binding StartTraceCommand}"
                                            Style="{StaticResource SmallButtonStyle}" />
                                    <Button Content="stop"
                                            Command="{Binding StopTraceCommand}"
                                            Style="{StaticResource SmallButtonStyle}"
                                            Margin="0" />
                                </WrapPanel>
                                <ListBox ItemsSource="{Binding SelectedClient.TraceSequences}"
                                         SelectedItem="{Binding SelectedTrace}"
                                         Background="#FFF9EC"
                                         Foreground="{StaticResource InkBrush}"
                                         BorderBrush="{StaticResource BorderBrushSoft}"
                                         MinHeight="180"
                                         MaxHeight="220"
                                         Style="{StaticResource PanelListBoxStyle}"
                                         ItemContainerStyle="{StaticResource ListBoxItemChromeStyle}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate DataType="{x:Type models:TraceSequence}">
                                            <StackPanel Margin="0,4">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                                <TextBlock Text="{Binding LastUpdatedUtc, StringFormat='Updated: {0:yyyy-MM-dd HH:mm:ss}'}"
                                                           Foreground="{StaticResource MutedInkBrush}"
                                                           FontSize="11" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <TextBox Style="{StaticResource EditorTextBoxStyle}"
                                         Text="{Binding SelectedTrace.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         IsEnabled="{Binding SelectedTrace, Converter={StaticResource NullToBoolean}}" />
                                <TextBlock Text="Trace points"
                                           Foreground="{StaticResource InkBrush}"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Margin="0,14,0,0" />
                                <TextBlock Text="{Binding SelectedTracePointSummary}"
                                           Foreground="{StaticResource InkBrush}"
                                           Margin="0,6,0,0"
                                           TextWrapping="Wrap" />
                                <ListBox ItemsSource="{Binding SelectedTrace.Points}"
                                         SelectedItem="{Binding SelectedTracePoint}"
                                         Background="#FFF9EC"
                                         Foreground="{StaticResource InkBrush}"
                                         BorderBrush="{StaticResource BorderBrushSoft}"
                                         MinHeight="180"
                                         MaxHeight="220"
                                         Margin="0,8,0,0"
                                         IsEnabled="{Binding SelectedTrace, Converter={StaticResource NullToBoolean}}"
                                         Style="{StaticResource PanelListBoxStyle}"
                                         ItemContainerStyle="{StaticResource ListBoxItemChromeStyle}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate DataType="{x:Type models:NormalizedPoint}">
                                            <DockPanel Margin="0,4">
                                                <TextBlock Text="{Binding X, StringFormat='X {0:0.000}'}"
                                                           FontWeight="SemiBold" />
                                                <TextBlock DockPanel.Dock="Right"
                                                           Text="{Binding Y, StringFormat='Y {0:0.000}'}"
                                                           Foreground="{StaticResource MutedInkBrush}" />
                                            </DockPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <WrapPanel Margin="0,10,0,0">
                                    <Button Content="remove point"
                                            Command="{Binding RemoveTracePointCommand}"
                                            Style="{StaticResource SmallButtonStyle}" />
                                    <Button Content="move up"
                                            Command="{Binding MoveTracePointUpCommand}"
                                            Style="{StaticResource SmallButtonStyle}" />
                                    <Button Content="move down"
                                            Command="{Binding MoveTracePointDownCommand}"
                                            Style="{StaticResource SmallButtonStyle}"
                                            Margin="0" />
                                </WrapPanel>
                                <WrapPanel Margin="0,8,0,0">
                                    <Button Content="nudge left"
                                            Command="{Binding NudgeTracePointLeftCommand}"
                                            Style="{StaticResource SmallButtonStyle}" />
                                    <Button Content="nudge up"
                                            Command="{Binding NudgeTracePointUpCommand}"
                                            Style="{StaticResource SmallButtonStyle}" />
                                    <Button Content="nudge down"
                                            Command="{Binding NudgeTracePointDownCommand}"
                                            Style="{StaticResource SmallButtonStyle}" />
                                    <Button Content="nudge right"
                                            Command="{Binding NudgeTracePointRightCommand}"
                                            Style="{StaticResource SmallButtonStyle}"
                                            Margin="0" />
                                </WrapPanel>
                                <Button Content="clear all points"
                                        Command="{Binding ClearTracePointsCommand}"
                                        Style="{StaticResource SmallButtonStyle}"
                                        Margin="0,8,0,0" />
                                <TextBlock Text="When recording is armed, clicks made over the bound client window are stored into the selected trace."
                                           Foreground="{StaticResource MutedInkBrush}"
                                           Margin="0,10,0,0"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2"
                                Style="{StaticResource CardBorderStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <WrapPanel Grid.Row="0" Margin="0,0,0,10">
                                    <TextBlock Text="Bindings"
                                               Foreground="{StaticResource InkBrush}"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Margin="0,0,12,0" />
                                    <Button Content="add binding"
                                            Command="{Binding AddBindingCommand}"
                                            Style="{StaticResource PrimaryButtonStyle}" />
                                    <Button Content="remove binding"
                                            Command="{Binding RemoveBindingCommand}"
                                            Style="{StaticResource SmallButtonStyle}"
                                            Margin="0" />
                                </WrapPanel>

                                <ListBox Grid.Row="1"
                                         ItemsSource="{Binding SelectedClient.Bindings}"
                                         SelectedItem="{Binding SelectedBinding}"
                                         Background="#FFF9EC"
                                         Foreground="{StaticResource InkBrush}"
                                         BorderBrush="{StaticResource BorderBrushSoft}"
                                         MinHeight="180"
                                         Margin="0,0,0,14"
                                         Style="{StaticResource PanelListBoxStyle}"
                                         ItemContainerStyle="{StaticResource ListBoxItemChromeStyle}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate DataType="{x:Type models:MacroBinding}">
                                            <DockPanel Margin="0,4">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                                <TextBlock DockPanel.Dock="Right"
                                                           Text="{Binding TriggerHotkey}"
                                                           Foreground="{StaticResource AccentDeepBrush}" />
                                            </DockPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <Grid Grid.Row="2"
                                      IsEnabled="{Binding SelectedBinding, Converter={StaticResource NullToBoolean}}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Margin="0,0,12,0">
                                        <TextBlock Text="Binding name" Foreground="{StaticResource InkBrush}" />
                                        <TextBox Style="{StaticResource EditorTextBoxStyle}"
                                                 Text="{Binding SelectedBinding.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <CheckBox Content="binding enabled"
                                                  IsChecked="{Binding SelectedBinding.IsEnabled, Mode=TwoWay}"
                                                  Foreground="{StaticResource InkBrush}"
                                                  Margin="0,10,0,0" />

                                        <TextBlock Text="Trigger hotkey" Foreground="{StaticResource InkBrush}" Margin="0,14,0,0" />
                                        <TextBox Style="{StaticResource EditorTextBoxStyle}"
                                                 Text="{Binding SelectedBinding.TriggerHotkey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 infra:HotkeyCapture.IsEnabled="True" />

                                        <TextBlock Text="Input key sent to target client" Foreground="{StaticResource InkBrush}" Margin="0,14,0,0" />
                                        <TextBox Style="{StaticResource EditorTextBoxStyle}"
                                                 Text="{Binding SelectedBinding.InputKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 infra:HotkeyCapture.IsEnabled="True" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Execution mode" Foreground="{StaticResource InkBrush}" />
                                        <ComboBox Style="{StaticResource EditorComboBoxStyle}"
                                                  ItemsSource="{Binding ExecutionModes}"
                                                  SelectedItem="{Binding SelectedBinding.ExecutionMode, Mode=TwoWay}" />

                                        <TextBlock Text="Trace source" Foreground="{StaticResource InkBrush}" Margin="0,14,0,0" />
                                        <ComboBox Style="{StaticResource EditorComboBoxStyle}"
                                                  ItemsSource="{Binding DataContext.SelectedClient.TraceSequences, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  DisplayMemberPath="Name"
                                                  SelectedValuePath="Id"
                                                  SelectedValue="{Binding SelectedBinding.TraceSequenceId, Mode=TwoWay}" />

                                        <TextBlock Text="Post-input delay (ms)" Foreground="{StaticResource InkBrush}" Margin="0,14,0,0" />
                                        <TextBox Style="{StaticResource EditorTextBoxStyle}"
                                                 Text="{Binding SelectedBindingPostInputDelayText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 infra:NumericTextBoxBehavior.IsEnabled="True"
                                                 infra:NumericTextBoxBehavior.AllowBlank="False" />

                                        <TextBlock Text="Inter-click delay (ms)" Foreground="{StaticResource InkBrush}" Margin="0,14,0,0" />
                                        <TextBox Style="{StaticResource EditorTextBoxStyle}"
                                                 Text="{Binding SelectedBindingInterClickDelayText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 infra:NumericTextBoxBehavior.IsEnabled="True"
                                                 infra:NumericTextBoxBehavior.AllowBlank="False" />

                                        <TextBlock Text="Click count override (blank uses trace/default)"
                                                   Foreground="{StaticResource InkBrush}"
                                                   Margin="0,14,0,0" />
                                        <TextBox Style="{StaticResource EditorTextBoxStyle}"
                                                 Text="{Binding SelectedBindingClickCountOverrideText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 infra:NumericTextBoxBehavior.IsEnabled="True"
                                                 infra:NumericTextBoxBehavior.AllowBlank="True" />

                                        <TextBlock Text="{Binding BindingEditorValidationMessage}"
                                                   Foreground="{StaticResource AlertBrush}"
                                                   Margin="0,10,0,0"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </ScrollViewer>

            <Border Grid.Row="2"
                    Margin="16,0,16,16"
                    Padding="12,10"
                    Background="{StaticResource CardBrush}"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    CornerRadius="16">
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{StaticResource InkBrush}"
                           TextWrapping="Wrap" />
            </Border>
        </Grid>
    </Grid>
</Window>
