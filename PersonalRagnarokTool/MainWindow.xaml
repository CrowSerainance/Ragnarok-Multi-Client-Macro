<Window x:Class="PersonalRagnarokTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:infra="clr-namespace:PersonalRagnarokTool.Infrastructure"
        xmlns:models="clr-namespace:PersonalRagnarokTool.Core.Models;assembly=PersonalRagnarokTool.Core"
        Title="Personal Ragnarok Tool"
        Width="1320"
        Height="800"
        MinWidth="1080"
        MinHeight="680"
        Background="#F0F0F0"
        FontFamily="Segoe UI"
        FontSize="14">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <infra:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVisibility" />
        <infra:NullToBooleanConverter x:Key="NullToBoolean" />
        <infra:BoolToStatusBrushConverter x:Key="BoolToStatusBrush" />

        <!-- HIGH CONTRAST COLOR PALETTE -->
        <SolidColorBrush x:Key="SidebarBg" Color="#1E1E2E" />
        <SolidColorBrush x:Key="SidebarCard" Color="#2A2A3C" />
        <SolidColorBrush x:Key="SidebarSelected" Color="#3D3D56" />
        <SolidColorBrush x:Key="SidebarText" Color="#FFFFFF" />
        <SolidColorBrush x:Key="SidebarMuted" Color="#9090A0" />
        <SolidColorBrush x:Key="TealAccent" Color="#00D4AA" />

        <SolidColorBrush x:Key="CardBg" Color="#FFFFFF" />
        <SolidColorBrush x:Key="CardBorder" Color="#C0C0C0" />
        <SolidColorBrush x:Key="InkBrush" Color="#111111" />
        <SolidColorBrush x:Key="MutedInk" Color="#555555" />
        <SolidColorBrush x:Key="LabelInk" Color="#333333" />

        <SolidColorBrush x:Key="PrimaryBlue" Color="#2563EB" />
        <SolidColorBrush x:Key="PrimaryBlueHover" Color="#1D4ED8" />
        <SolidColorBrush x:Key="SecondaryBg" Color="#E5E7EB" />
        <SolidColorBrush x:Key="SecondaryBorder" Color="#B0B0B0" />

        <SolidColorBrush x:Key="InputBorder" Color="#9CA3AF" />
        <SolidColorBrush x:Key="InputFocusBorder" Color="#2563EB" />
        <SolidColorBrush x:Key="InputBg" Color="#FFFFFF" />

        <SolidColorBrush x:Key="ActiveGreen" Color="#10B981" />
        <SolidColorBrush x:Key="InactiveRed" Color="#EF4444" />
        <SolidColorBrush x:Key="AlertBrush" Color="#DC2626" />

        <SolidColorBrush x:Key="ListHover" Color="#EFF6FF" />
        <SolidColorBrush x:Key="ListSelected" Color="#DBEAFE" />

        <!-- CARD STYLE -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBg}" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="1" Opacity="0.10" Color="#000000" />
                </Setter.Value>
            </Setter>
        </Style>

        <!-- PRIMARY BUTTON -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBlue}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource PrimaryBlueHover}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- SECONDARY BUTTON -->
        <Style x:Key="SecondaryBtn" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource SecondaryBg}" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource SecondaryBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource ListHover}" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource PrimaryBlue}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TEXT BOX -->
        <Style x:Key="EditorTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource InputBg}" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource InputBorder}" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Margin" Value="0,4,0,0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="CaretBrush" Value="{StaticResource InkBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource InputFocusBorder}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- COMBO BOX -->
        <Style x:Key="EditorCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource InputBg}" />
            <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource InputBorder}" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="Margin" Value="0,4,0,0" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <!-- LABEL -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource LabelInk}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,12,0,0" />
        </Style>

        <!-- SIDEBAR LISTBOX ITEM -->
        <Style x:Key="SidebarItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBd" Background="Transparent" CornerRadius="10" BorderThickness="3,0,0,0" BorderBrush="Transparent">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBd" Property="Background" Value="{StaticResource SidebarSelected}" />
                                <Setter TargetName="ItemBd" Property="BorderBrush" Value="{StaticResource TealAccent}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBd" Property="Background" Value="#33FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- MAIN LIST ITEM -->
        <Style x:Key="MainListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBd" Background="Transparent" CornerRadius="6" Padding="8,6">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBd" Property="Background" Value="{StaticResource ListSelected}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBd" Property="Background" Value="{StaticResource ListHover}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- HOTKEY CAPTURE BOX -->
        <Style x:Key="HotkeyCaptureLarge" TargetType="TextBox" BasedOn="{StaticResource EditorTextBox}">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="MinHeight" Value="80" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderThickness" Value="3" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryBlue}" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0" Width="{Binding SidebarWidth}" Background="{StaticResource SidebarBg}">
            <Grid Visibility="{Binding IsSidebarCollapsed, Converter={StaticResource InverseBoolToVisibility}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0" Margin="16,16,16,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Personal Ragnarok Tool" Foreground="{StaticResource SidebarText}" FontSize="22" FontWeight="Bold" />
                        <Button Grid.Column="1" Content="{Binding SidebarToggleLabel}" Command="{Binding ToggleSidebarCommand}" Style="{StaticResource SecondaryBtn}" Width="32" Height="32" Padding="0" Margin="0" Foreground="{StaticResource SidebarText}" Background="{StaticResource SidebarCard}" />
                    </Grid>
                    <TextBlock Text="Internal 4R Edition" Foreground="{StaticResource SidebarMuted}" FontSize="12" Margin="0,4,0,0" />
                </StackPanel>

                <!-- Global Toggle Badge -->
                <Border Grid.Row="1" Margin="16,16,16,0" Padding="14,10" CornerRadius="10" Background="{Binding IsGlobalActive, Converter={StaticResource BoolToStatusBrush}}">
                    <StackPanel>
                        <TextBlock Text="{Binding GlobalToggleStatusText}" Foreground="White" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" />
                        <TextBlock Text="{Binding GlobalToggleComboText}" Foreground="#FFFFFFCC" FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <!-- Toggle Key Reassignment -->
                <Border Grid.Row="2" Margin="16,8,16,0" Padding="10,8" CornerRadius="8" Background="{StaticResource SidebarCard}">
                    <StackPanel>
                        <TextBlock Text="Toggle Hotkey" Foreground="{StaticResource SidebarMuted}" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="6" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ComboBox ItemsSource="{Binding ModifierOptions}" SelectedItem="{Binding GlobalToggleModifier, Mode=TwoWay}" FontSize="12" Padding="4,3" Background="{StaticResource SidebarSelected}" Foreground="{StaticResource SidebarText}" BorderThickness="1" BorderBrush="{StaticResource SidebarMuted}" />
                            <TextBox Grid.Column="2" Text="{Binding GlobalToggleKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" infra:HotkeyCapture.IsEnabled="True" FontSize="12" Padding="4,3" TextAlignment="Center" Background="{StaticResource SidebarSelected}" Foreground="{StaticResource SidebarText}" BorderThickness="1" BorderBrush="{StaticResource SidebarMuted}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Client Buttons -->
                <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="16,12,16,0">
                    <Button Content="+ Client" Command="{Binding AddClientCommand}" Style="{StaticResource PrimaryBtn}" FontSize="12" Padding="10,5" />
                    <Button Content="- Client" Command="{Binding RemoveSelectedClientCommand}" Style="{StaticResource SecondaryBtn}" FontSize="12" Padding="10,5" Margin="0" Foreground="{StaticResource SidebarText}" Background="{StaticResource SidebarCard}" />
                </StackPanel>

                <!-- Client List -->
                <ListBox Grid.Row="4" Margin="12,12,12,12" ItemsSource="{Binding ClientProfiles}" SelectedItem="{Binding SelectedClient}" Background="Transparent" BorderThickness="0" ItemContainerStyle="{StaticResource SidebarItemStyle}">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:ClientProfile}">
                            <Border Padding="12,10" Background="{StaticResource SidebarCard}" CornerRadius="10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding DisplayName}" Foreground="{StaticResource SidebarText}" FontWeight="SemiBold" FontSize="15" />
                                        <TextBlock Text="{Binding BoundWindowDisplayText}" Foreground="{StaticResource SidebarMuted}" FontSize="11" TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                                    </StackPanel>
                                    <Ellipse Grid.Column="1" Width="12" Height="12" VerticalAlignment="Center" Fill="{Binding IsActive, Converter={StaticResource BoolToStatusBrush}}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- HEADER BAR -->
            <Border Grid.Row="0" Margin="16,16,16,8" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Personal Ragnarok Tool" Foreground="{StaticResource InkBrush}" FontSize="22" FontWeight="Bold" />
                        <TextBlock Text="Aggressive internal logic sync. Select a tab to configure features." Foreground="{StaticResource MutedInk}" FontSize="13" Margin="0,4,0,0" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="Refresh Windows" Command="{Binding RefreshWindowsCommand}" Style="{StaticResource SecondaryBtn}" />
                        <Button Content="Save Config" Command="{Binding SaveCommand}" Style="{StaticResource PrimaryBtn}" Margin="0" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- TABS -->
            <TabControl Grid.Row="1" Margin="16,0,16,16" Background="Transparent" BorderThickness="0">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="HeaderTemplate">
                            <Setter.Value>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontSize="13" FontWeight="SemiBold" Padding="8,6" />
                                </DataTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>

                <!-- ═══════════ TAB: MACROS ═══════════ -->
                <TabItem Header="Macros">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="0,16,0,0">
                            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="260" />
                                        <ColumnDefinition Width="320" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Selected Client" Style="{StaticResource FieldLabel}" Margin="0" />
                                        <TextBox Style="{StaticResource EditorTextBox}" Text="{Binding SelectedClient.DisplayName}" />
                                        <CheckBox Content="Enabled" IsChecked="{Binding SelectedClient.IsEnabled}" Margin="0,10,0,0" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="20,0">
                                        <TextBlock Text="Window Binding" Style="{StaticResource FieldLabel}" Margin="0" />
                                        <ComboBox ItemsSource="{Binding AvailableWindows}" SelectedItem="{Binding SelectedAvailableWindow}" DisplayMemberPath="DisplayText" Style="{StaticResource EditorCombo}" />
                                        <WrapPanel Margin="0,10,0,0">
                                            <Button Content="Bind" Command="{Binding BindSelectedClientCommand}" Style="{StaticResource PrimaryBtn}" />
                                            <Button Content="Unbind" Command="{Binding UnbindSelectedClientCommand}" Style="{StaticResource SecondaryBtn}" />
                                        </WrapPanel>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Status" Style="{StaticResource FieldLabel}" Margin="0" />
                                        <TextBlock Text="{Binding SelectedClientBindingStatus}" FontWeight="Bold" Foreground="{StaticResource ActiveGreen}" FontSize="16" />
                                        <TextBlock Text="{Binding SelectedClientBindingDetail}" TextWrapping="Wrap" Foreground="{StaticResource MutedInk}" FontSize="12" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                                <StackPanel>
                                    <WrapPanel Margin="0,0,0,8">
                                        <TextBlock Text="Macros" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,12,0" />
                                        <Button Content="+ Add" Command="{Binding AddBindingCommand}" Style="{StaticResource PrimaryBtn}" />
                                        <Button Content="Remove" Command="{Binding RemoveBindingCommand}" Style="{StaticResource SecondaryBtn}" />
                                    </WrapPanel>
                                    <ListBox ItemsSource="{Binding SelectedClient.Bindings}" SelectedItem="{Binding SelectedBinding}" MinHeight="60" MaxHeight="140" ItemContainerStyle="{StaticResource MainListItemStyle}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                                    <TextBlock Grid.Column="1" Text="{Binding TriggerKey, StringFormat='[{0}]'}" Foreground="{StaticResource PrimaryBlue}" FontWeight="Bold" />
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource CardStyle}" IsEnabled="{Binding SelectedBinding, Converter={StaticResource NullToBoolean}}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="280" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Margin="0,0,20,0">
                                        <TextBlock Text="Trigger Key" Style="{StaticResource FieldLabel}" Margin="0" />
                                        <TextBox Style="{StaticResource HotkeyCaptureLarge}" Text="{Binding SelectedBinding.TriggerKey}" infra:HotkeyCapture.IsEnabled="True" />
                                        <CheckBox Content="Repeat Macro" IsChecked="{Binding SelectedBinding.IsEnabled}" Margin="0,10,0,0" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Steps" FontSize="16" FontWeight="Bold" />
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <TextBlock Text="Interval (ms)" VerticalAlignment="Center" Margin="0,0,8,0" />
                                                <TextBox Width="60" Text="{Binding SelectedBindingIntervalMsText}" Style="{StaticResource EditorTextBox}" Margin="0" />
                                            </StackPanel>
                                        </Grid>
                                        <ListBox ItemsSource="{Binding SelectedBinding.Steps}" SelectedItem="{Binding SelectedStep}" MinHeight="100" ItemContainerStyle="{StaticResource MainListItemStyle}">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="60" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="Key:" VerticalAlignment="Center" Margin="0,0,8,0" />
                                                        <TextBox Grid.Column="1" Text="{Binding Key}" infra:HotkeyCapture.IsEnabled="True" Style="{StaticResource EditorTextBox}" Margin="0" />
                                                        <TextBlock Grid.Column="2" Text="Delay:" VerticalAlignment="Center" Margin="12,0,8,0" />
                                                        <TextBox Grid.Column="3" Text="{Binding DelayMs}" Style="{StaticResource EditorTextBox}" Margin="0" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                        <WrapPanel Margin="0,10,0,0">
                                            <Button Content="+ Step" Command="{Binding AddStepCommand}" Style="{StaticResource PrimaryBtn}" />
                                            <Button Content="- Step" Command="{Binding RemoveStepCommand}" Style="{StaticResource SecondaryBtn}" />
                                        </WrapPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ═══════════ TAB: AUTOPOT ═══════════ -->
                <TabItem Header="Autopot">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="0,16,0,0">
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Autopot Settings" FontSize="18" FontWeight="Bold" />
                                        <CheckBox Grid.Column="1" Content="Enabled" IsChecked="{Binding SelectedClient.Autopot.Enabled}" VerticalAlignment="Center" />
                                    </Grid>
                                    <Separator Margin="0,12" />
                                    <UniformGrid Columns="2">
                                        <StackPanel Margin="0,0,10,0">
                                            <TextBlock Text="HP Potion" FontWeight="Bold" />
                                            <TextBlock Text="Key" Style="{StaticResource FieldLabel}" />
                                            <TextBox Text="{Binding SelectedClient.Autopot.HpKey}" infra:HotkeyCapture.IsEnabled="True" Style="{StaticResource EditorTextBox}" />
                                            <TextBlock Text="{Binding SelectedClient.Autopot.HpThreshold, StringFormat='{}{0}%'}" />
                                            <Slider Minimum="0" Maximum="100" Value="{Binding SelectedClient.Autopot.HpThreshold}" IsSnapToTickEnabled="True" />
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="SP Potion" FontWeight="Bold" />
                                            <TextBlock Text="Key" Style="{StaticResource FieldLabel}" />
                                            <TextBox Text="{Binding SelectedClient.Autopot.SpKey}" infra:HotkeyCapture.IsEnabled="True" Style="{StaticResource EditorTextBox}" />
                                            <TextBlock Text="{Binding SelectedClient.Autopot.SpThreshold, StringFormat='{}{0}%'}" />
                                            <Slider Minimum="0" Maximum="100" Value="{Binding SelectedClient.Autopot.SpThreshold}" IsSnapToTickEnabled="True" />
                                        </StackPanel>
                                    </UniformGrid>
                                    <TextBlock Text="Check Interval (ms)" Style="{StaticResource FieldLabel}" />
                                    <Slider Minimum="15" Maximum="500" Value="{Binding SelectedClient.Autopot.DelayMs}" IsSnapToTickEnabled="True" Width="200" HorizontalAlignment="Left" />
                                    <TextBlock Text="{Binding SelectedClient.Autopot.DelayMs, StringFormat='{}{0} ms'}" FontSize="12" Foreground="{StaticResource MutedInk}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ═══════════ TAB: YGG AUTOPOT ═══════════ -->
                <TabItem Header="Ygg Autopot">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="0,16,0,0">
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Yggdrasil Autopot Settings" FontSize="18" FontWeight="Bold" />
                                        <CheckBox Grid.Column="1" Content="Enabled" IsChecked="{Binding SelectedClient.YggAutopot.Enabled}" VerticalAlignment="Center" />
                                    </Grid>
                                    <Separator Margin="0,12" />
                                    <UniformGrid Columns="2">
                                        <StackPanel Margin="0,0,10,0">
                                            <TextBlock Text="Ygg HP" FontWeight="Bold" />
                                            <TextBlock Text="Key" Style="{StaticResource FieldLabel}" />
                                            <TextBox Text="{Binding SelectedClient.YggAutopot.HpKey}" infra:HotkeyCapture.IsEnabled="True" Style="{StaticResource EditorTextBox}" />
                                            <TextBlock Text="{Binding SelectedClient.YggAutopot.HpThreshold, StringFormat='{}{0}%'}" />
                                            <Slider Minimum="0" Maximum="100" Value="{Binding SelectedClient.YggAutopot.HpThreshold}" IsSnapToTickEnabled="True" />
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="Ygg SP" FontWeight="Bold" />
                                            <TextBlock Text="Key" Style="{StaticResource FieldLabel}" />
